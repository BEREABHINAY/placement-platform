# ---- Server ----
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ---- Database ----
# Get a free cluster at https://www.mongodb.com/atlas
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/placement-platform

# ---- Auth ----
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d
OTP_SECRET=replace_with_another_long_random_string
OTP_EXPIRY_MINUTES=10

# ---- Email (Nodemailer) ----
# Works with Gmail (use an App Password, not your real password),
# or any SMTP provider (Brevo, Mailtrap, SendGrid SMTP, etc.)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=b16e94001@smtp-brevo.com
SMTP_PASS=bskwlww349WtHeF
EMAIL_FROM="Placement Platform <no-reply@placementplatform.com>"


# If SMTP vars are left blank, OTPs are printed to the server console
# instead of emailed — handy for local dev without email credentials.
